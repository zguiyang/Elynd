{
  "name": "@elynd/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later OR Commercial",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "run:jobs": "node ace jobs:listen --concurrency=3",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#constants": "./app/constants/index.js",
    "#constants/*": "./app/constants/*.js",
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#utils/*": "./app/utils/*.js",
    "#workers/*": "./app/workers/*.js",
    "#types/*": "./app/types/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#jobs/*": "./app/jobs/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^4.2.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/jsdom": "^27.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "eslint": "^9.26.0",
    "eslint-plugin-import": "^2.32.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.1.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.1.1",
    "@adonisjs/mail": "^10.0.0",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/transmit": "^3.0.1",
    "@vinejs/vine": "^4.3.0",
    "adonisjs-jobs": "^0.2.0",
    "edge.js": "^6.5.0",
    "epub": "^2.1.1",
    "jsdom": "^27.4.0",
    "luxon": "^3.7.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "mqtt": "^5.15.0",
    "natural": "^8.1.1",
    "node-cron": "^4.2.1",
    "open-graph-scraper": "^6.11.0",
    "openai": "^6.17.0",
    "pg": "^8.17.2",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "prettier": "@adonisjs/prettier-config"
}
